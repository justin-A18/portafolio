---
interface Props {
	name:
		| "cloud-sun"
		| "clock"
		| "user"
		| "briefcase"
		| "grid"
		| "code"
		| "mail"
		| "arrow-up-right"
		| "sparkles";
	label: string;
}

const { name, label } = Astro.props;
---

{
	name === "cloud-sun" && (
		<svg
			class="block size-5 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]"
			viewBox="0 0 24 24"
			aria-label={label}
			role="img"
		>
			<path d="M12 2.75v2.5" />
			<path d="m4.93 4.93 1.77 1.77" />
			<path d="M2.75 12h2.5" />
			<path d="m19.07 4.93-1.77 1.77" />
			<path d="M17.25 12a5.25 5.25 0 0 0-10.18-1.8" />
			<path d="M8.4 19.25h8.1a3.25 3.25 0 0 0 .28-6.49 4.8 4.8 0 0 0-8.98 1.2 2.66 2.66 0 0 0 .6 5.29Z" />
		</svg>
	)
}

{
	name === "clock" && (
		<svg
			class="block size-[1.2rem] fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]"
			viewBox="0 0 24 24"
			aria-label={label}
			role="img"
		>
			<circle cx="12" cy="12" r="8.25" />
			<path d="M12 7.5V12l3 2" />
		</svg>
	)
}

{
	name === "user" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<path d="M20 21a8 8 0 0 0-16 0" />
			<circle cx="12" cy="8" r="4" />
		</svg>
	)
}

{
	name === "briefcase" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1" />
			<rect x="4" y="6" width="16" height="13" rx="2" />
			<path d="M4 12h16" />
		</svg>
	)
}

{
	name === "grid" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<rect x="4" y="4" width="6" height="6" rx="1.5" />
			<rect x="14" y="4" width="6" height="6" rx="1.5" />
			<rect x="4" y="14" width="6" height="6" rx="1.5" />
			<rect x="14" y="14" width="6" height="6" rx="1.5" />
		</svg>
	)
}

{
	name === "code" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<path d="m8 9-3 3 3 3" />
			<path d="m16 9 3 3-3 3" />
			<path d="m14 5-4 14" />
		</svg>
	)
}

{
	name === "mail" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<rect x="4" y="6" width="16" height="12" rx="2" />
			<path d="m5 8 7 5 7-5" />
		</svg>
	)
}

{
	name === "arrow-up-right" && (
		<svg class="block size-3.5 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<path d="M7 17 17 7" />
			<path d="M9 7h8v8" />
		</svg>
	)
}

{
	name === "sparkles" && (
		<svg class="block size-4 fill-none stroke-current stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]" viewBox="0 0 24 24" aria-label={label} role="img">
			<path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3Z" />
			<path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14Z" />
			<path d="M5 13l.7 1.8L7.5 15.5l-1.8.7L5 18l-.7-1.8-1.8-.7 1.8-.7L5 13Z" />
		</svg>
	)
}
