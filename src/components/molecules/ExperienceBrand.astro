---
interface Props {
	name: string;
	shortName: string;
}

const { name, shortName } = Astro.props;
---

<li class="group flex flex-col items-center gap-2">
	<div
		class="grid size-8 place-items-center bg-[var(--color-surface)] text-xs font-semibold text-white ring-1 ring-[var(--color-border)] transition-colors group-hover:bg-[#2a2a2a]"
		aria-hidden="true"
	>
		{shortName}
	</div>
	<span class="sr-only">{name}</span>
</li>
