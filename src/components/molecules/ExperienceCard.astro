---
interface Props {
	name: string;
	role: string;
	period: string;
	description: string;
	mark: string;
	logo?: ImageMetadata;
}

const { name, role, period, description, mark, logo } = Astro.props;
---

<article
	class="group border-t border-[var(--color-border)] py-5 transition-colors hover:border-[var(--color-accent-muted)]"
>
	<div class="grid gap-4 sm:grid-cols-[3.75rem_minmax(0,1fr)] sm:items-start">
		<div class="relative size-14 shrink-0">
			<div
				class="absolute inset-0 rounded-2xl bg-[color-mix(in_srgb,var(--color-accent)_14%,transparent)] opacity-0 blur-md transition-opacity duration-300 group-hover:opacity-100"
				aria-hidden="true"
			>
			</div>

			{
				logo ? (
					<img
						class="max-h-12 max-w-12 object-contain rounded-lg"
						src={logo.src}
						alt={`Logo de ${name}`}
						loading="lazy"
					/>
				) : (
					<span class="font-mono text-xs font-medium text-white">{mark}</span>
				)
			}
		</div>

		<div class="min-w-0">
			<div
				class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1"
			>
				<h3 class="text-sm font-medium text-white">{name}</h3>
				<p
					class="font-mono text-[0.6875rem] uppercase tracking-[0.12em] text-[var(--color-text-subtle)]"
				>
					{period}
				</p>
			</div>
			<p class="mt-1 text-sm text-[var(--color-text-muted)]">{role}</p>
			<p class="mt-3 text-sm leading-6 text-[var(--color-text-muted)]">
				{description}
			</p>
		</div>
	</div>
</article>
