---
interface Props {
	title: string;
	type: string;
	description: string;
	tags: string[];
	variant: "terminal" | "desktop" | "pixel";
}

const { title, type, description, tags, variant } = Astro.props;
---

<article class="group overflow-hidden rounded-2xl border border-white/10 bg-[var(--color-surface)] transition duration-200 hover:-translate-y-0.5 hover:border-white/20">
	<div class="relative aspect-[16/10] overflow-hidden bg-[#111]">
		{variant === "terminal" && (
			<div class="h-full p-4 font-mono text-[0.625rem] leading-5 text-[#8f8f8f]">
				<div class="mb-4 flex gap-1.5">
					<span class="size-2 rounded-full bg-[#686868]" />
					<span class="size-2 rounded-full bg-[#8f8f8f]" />
					<span class="size-2 rounded-full bg-[#bbbbbb]" />
				</div>
				<p class="text-white">$ uname -a</p>
				<p>Linux justin-workstation · hyprland · zsh</p>
				<p class="mt-3 text-white">$ pnpm dev</p>
				<p>Astro ready in 428ms</p>
			</div>
		)}

		{variant === "desktop" && (
			<div class="grid h-full grid-cols-[1fr_4rem] gap-3 p-3">
				<div class="rounded-xl border border-white/10 bg-[#0d0d0d] p-3">
					<div class="h-3 w-24 rounded-full bg-white/15" />
					<div class="mt-4 grid grid-cols-3 gap-2">
						<span class="h-10 rounded-lg bg-white/10" />
						<span class="h-10 rounded-lg bg-white/5" />
						<span class="h-10 rounded-lg bg-white/10" />
					</div>
					<div class="mt-3 h-16 rounded-lg bg-white/5" />
				</div>
				<div class="rounded-xl border border-white/10 bg-[#171717] p-2">
					<div class="space-y-2">
						<span class="block h-6 rounded-md bg-white/10" />
						<span class="block h-6 rounded-md bg-white/5" />
						<span class="block h-6 rounded-md bg-white/10" />
					</div>
				</div>
			</div>
		)}

		{variant === "pixel" && (
			<div class="grid h-full place-items-center bg-[#0d0d0d]">
				<div class="grid grid-cols-8 gap-1">
					{Array.from({ length: 64 }).map((_, index) => (
						<span
							class:list={[
								"size-3 rounded-[2px]",
								index % 7 === 0 || index % 11 === 0 ? "bg-white" : index % 3 === 0 ? "bg-[#686868]" : "bg-[#1f1f1f]",
							]}
						/>
					))}
				</div>
			</div>
		)}
	</div>

	<div class="p-4">
		<div class="flex items-baseline justify-between gap-3">
			<h3 class="text-sm font-medium text-white">{title}</h3>
			<p class="font-mono text-[0.625rem] uppercase tracking-[0.14em] text-[var(--color-border)]">{type}</p>
		</div>
		<p class="mt-3 text-sm leading-6 text-[var(--color-text-muted)]">{description}</p>
		<ul class="mt-4 flex flex-wrap gap-2">
			{tags.map((tag) => <li class="rounded-full bg-white/5 px-2 py-1 font-mono text-[0.625rem] uppercase tracking-[0.1em] text-[var(--color-text-muted)]">{tag}</li>)}
		</ul>
	</div>
</article>
