---
import GithubIcon from "../../assets/icons/github.svg";

interface Props {
	title: string;
	stack: string;
	description: string;
	image: ImageMetadata;
	githubUrl: string;
}

const { title, stack, description, image, githubUrl } = Astro.props;
---

<a
	class="group block overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] text-current no-underline transition duration-300 hover:border-[var(--color-accent-muted)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
	href={githubUrl}
	target="_blank"
	rel="noreferrer"
	aria-label={`Abrir repositorio de ${title} en GitHub`}
>
	<div class="p-5">
		<div class="flex items-start justify-between gap-4">
			<div>
				<p
					class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-[var(--color-text-subtle)]"
				>
					Featured project
				</p>
				<h3 class="mt-3 text-base font-medium leading-6 text-white">{title}</h3>
			</div>
			<span
				class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent-muted)] px-2.5 py-1 font-mono text-[0.625rem] uppercase tracking-[0.12em] text-[var(--color-accent)] transition-colors group-hover:border-[var(--color-accent)] group-hover:text-white"
			>
				<GithubIcon class="size-3.5" aria-hidden="true" />
				code
			</span>
		</div>

		<p class="mt-4 text-sm leading-6 text-[var(--color-text-muted)]">
			{description}
		</p>
		<p class="mt-4 font-mono text-xs leading-5 text-[var(--color-text-subtle)]">
			{stack}
		</p>
	</div>

	<div class="px-3 pb-3">
		<div
			class="relative aspect-[16/10] overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-background)]"
		>
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_80%_80%,color-mix(in_srgb,var(--color-accent)_18%,transparent),transparent_38%)]"
				aria-hidden="true"
			>
			</div>
			<img
				class="absolute bottom-[-clamp(2rem,12vw,3rem)] right-[-clamp(4rem,22vw,5rem)] w-[clamp(20rem,118vw,26rem)] max-w-none rounded-lg shadow-2xl shadow-black/50 transition duration-500 ease-out group-hover:-translate-x-4 group-hover:-translate-y-5 sm:group-hover:-translate-x-24 sm:-bottom-32 sm:-right-48 sm:w-[42rem] sm:group-hover:-translate-y-8"
				src={image.src}
				alt={`Preview de ${title}`}
				loading="lazy"
			/>
		</div>
	</div>
</a>
