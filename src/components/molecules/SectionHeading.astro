---
interface Props {
	title: string;
	eyebrow?: string;
}

const { title, eyebrow } = Astro.props;
---

<div class="mb-6 flex items-end justify-between gap-4">
	<h2 class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-text-subtle)]">
		{title}
	</h2>
	{eyebrow && <p class="font-mono text-[0.6875rem] uppercase tracking-[0.14em] text-[var(--color-text-subtle)]">{eyebrow}</p>}
</div>
