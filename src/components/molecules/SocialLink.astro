---
import Icon from "../atoms/Icon.astro";

interface Props {
	href: string;
	label: string;
}

const { href, label } = Astro.props;
---

<a
	class="inline-flex items-center gap-1.5 font-mono text-xs text-[var(--color-text-muted)] transition-colors hover:text-white"
	href={href}
	target={href.startsWith("http") ? "_blank" : undefined}
	rel={href.startsWith("http") ? "noreferrer" : undefined}
>
	<span>{label}</span>
	<Icon name="arrow-up-right" label={`Abrir ${label}`} />
</a>
