---
import type { SvgComponent } from "astro/types";

interface Props {
	name: string;
	icon: SvgComponent;
}

const { name, icon } = Astro.props;
const Icon = icon;
---

<li class="group min-w-0">
	<div
		class="grid aspect-square place-items-center rounded-xl bg-[var(--color-surface)] p-3 ring-1 ring-[var(--color-border)] transition duration-200 group-hover:-translate-y-0.5 group-hover:bg-[var(--color-surface-soft)] group-hover:ring-[var(--color-accent-muted)]"
	>
		<Icon class="size-7 object-contain" aria-hidden="true" />
	</div>
	<p class="mt-2 truncate text-center font-mono text-[0.6875rem] leading-4 text-[var(--color-text-muted)]">
		{name}
	</p>
</li>
