---
interface Props {
	name: string;
	role: string;
	period: string;
	description: string;
	mark: string;
	logo?: ImageMetadata;
}

const { name, role, period, description, mark, logo } = Astro.props;
---

<article class="group border-t border-[var(--color-border)] py-5">
	<div class="flex items-start gap-4">
		<div class="grid size-9 shrink-0 place-items-center rounded-xl bg-[var(--color-surface)] font-mono text-xs font-medium text-white ring-1 ring-[var(--color-border)] transition-colors group-hover:ring-[var(--color-accent-muted)]">
			{
				logo ? (
					<img
						class="max-h-5 max-w-5 object-contain"
						src={logo.src}
						alt={`Logo de ${name}`}
						loading="lazy"
					/>
				) : (
					mark
				)
			}
		</div>
		<div class="min-w-0 flex-1">
			<div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
				<h3 class="text-sm font-medium text-white">{name}</h3>
				<p class="font-mono text-[0.6875rem] uppercase tracking-[0.12em] text-[var(--color-text-subtle)]">{period}</p>
			</div>
			<p class="mt-1 text-sm text-[var(--color-text-muted)]">{role}</p>
			<p class="mt-3 text-sm leading-6 text-[var(--color-text-muted)]">{description}</p>
		</div>
	</div>
</article>
