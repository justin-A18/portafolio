---
import { socialLinks } from "../../constants/social-links";

const year = new Date().getFullYear();
---

<footer id="contact" class="scroll-mt-10 pb-28 pt-20" data-reveal>
	<div class="border-t border-[var(--color-border)] pt-8">
		<a
			class="block text-[clamp(3.6rem,18vw,8.2rem)] font-medium leading-[0.82] tracking-[-0.04em] text-white transition-colors hover:text-[var(--color-accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)]"
			href="mailto:justin.hv08@gmail.com"
			aria-label="Enviar correo a Justin"
		>
			@justindev
		</a>

		<div class="mt-8 grid gap-8 sm:grid-cols-[1fr_auto] sm:items-end">
			<div>
				<p class="text-sm leading-6 text-[var(--color-text-muted)]">
					Frontend Engineer construyendo productos rápidos, sólidos y pensados
					para escalar.
				</p>
				<a
					class="mt-3 inline-flex font-mono text-xs text-[var(--color-text-subtle)] transition-colors hover:text-white"
					href="mailto:justin.hv08@gmail.com"
				>
					justin.hv08@gmail.com
				</a>
			</div>

			<div class="sm:text-right">
				<p
					class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-[var(--color-text-subtle)]"
				>
					Social
				</p>
				<ul class="mt-3 flex flex-wrap gap-x-4 gap-y-2 sm:justify-end">
					{
						socialLinks.map((link) => (
							<li>
								<a
									class="font-mono text-xs text-[var(--color-text-muted)] transition-colors hover:text-white"
									href={link.href}
									target={link.href.startsWith("http") ? "_blank" : undefined}
									rel={link.href.startsWith("http") ? "noreferrer" : undefined}
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div
			class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-[var(--color-border)] pt-4 font-mono text-[0.6875rem] uppercase tracking-[0.14em] text-[var(--color-text-subtle)]"
		>
			<p>Lima, Peru</p>
			<p>© {year}</p>
		</div>
	</div>
</footer>
