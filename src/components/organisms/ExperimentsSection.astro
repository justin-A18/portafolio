---
import { experiments } from "../../constants/experiments";
import ExperimentCard from "../molecules/ExperimentCard.astro";
import SectionHeading from "../molecules/SectionHeading.astro";
---

<section id="experiments" class="scroll-mt-10 pt-14" data-reveal>
	<SectionHeading title="Experiments" eyebrow="lab notes" />
	<div class="grid gap-4 sm:grid-cols-2">
		{experiments.map((experiment) => <ExperimentCard {...experiment} />)}
	</div>
</section>
