---
import Icon from "../atoms/Icon.astro";

const navItems = [
	{ href: "#intro", label: "Intro", icon: "user" },
	{ href: "#experience", label: "Experience", icon: "briefcase" },
	{ href: "#projects", label: "Projects", icon: "grid" },
	{ href: "#experiments", label: "Experiments", icon: "sparkles" },
	{ href: "#toolkit", label: "Toolkit", icon: "code" },
	{ href: "#contact", label: "Contact", icon: "mail" },
] as const;
---

<nav
	class="fixed inset-x-0 bottom-5 z-50 mx-auto flex w-max max-w-[calc(100%-2rem)] items-center gap-1 rounded-2xl border border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] p-1.5 shadow-2xl shadow-black/40 backdrop-blur-md"
	aria-label="Navegacion principal"
>
	{navItems.map((item) => (
		<a
			class="group grid size-10 place-items-center rounded-xl text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface-soft)] hover:text-white data-[active]:bg-[var(--color-accent-muted)] data-[active]:text-white"
			href={item.href}
			aria-label={item.label}
			data-nav-link
		>
			<Icon name={item.icon} label={item.label} />
		</a>
	))}
</nav>
