---
import SectionHeading from "../molecules/SectionHeading.astro";
import WorkCard from "../molecules/WorkCard.astro";

const work = [
	{
		name: "Apertura digital de cuentas",
		role: "Banking onboarding · Next.js, BFF, Zod, Playwright",
		period: "Enterprise",
		mark: "01",
		description:
			"Flujo critico para apertura de cuentas de ahorro, con manejo de datos sensibles, validaciones estrictas y arquitectura frontend orientada a seguridad.",
	},
	{
		name: "RICM Tech",
		role: "Website · Astro, React, SEO tecnico, Lighthouse",
		period: "Freelance",
		mark: "02",
		description:
			"Sitio corporativo desde direccion visual hasta produccion, optimizado para performance, SEO tecnico y carga ultrarrapida.",
	},
	{
		name: "Sistema de sorteos",
		role: "Hackathon · React, TanStack Query, Zustand",
		period: "Code Quest",
		mark: "03",
		description:
			"App colaborativa con arquitectura por capas, hooks personalizados y reduccion de tiempos de carga mediante fetching eficiente.",
	},
];
---

<section id="work" class="scroll-mt-10 pt-14">
	<SectionHeading title="Work" eyebrow="selected builds" />
	<div>
		{work.map((item) => <WorkCard {...item} />)}
	</div>
</section>
